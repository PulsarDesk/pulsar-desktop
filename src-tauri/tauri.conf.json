{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Pulsar",
	"version": "0.1.0-dev.24",
	"identifier": "dev.pulsar.app",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Pulsar",
				"width": 1200,
				"height": 780,
				"center": true,
				"minWidth": 1200,
				"minHeight": 780,
				"decorations": false,
				"transparent": false,
				"resizable": true,
				"maximizable": true,
				"visible": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCNkUxNjQ4NTAyODE5M0MKUldROEdTaFFTQlp1VzZEK1pCdlp3ODNpLzltNk1aTms3aEUwUXZoMjdEY0oyb29oSVdWV0FOWmkK",
			"endpoints": [
				"https://github.com/PulsarDesk/pulsar/releases/download/updater-dev/latest-dev.json"
			],
			"windows": {
				"installMode": "quiet"
			}
		}
	}
}
