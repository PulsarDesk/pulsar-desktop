{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Pulsar",
	"version": "0.1.0-dev.5",
	"identifier": "dev.pulsar.app",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Pulsar",
				"width": 1200,
				"height": 780,
				"center": true,
				"minWidth": 1200,
				"minHeight": 780,
				"decorations": true,
				"transparent": false,
				"resizable": true,
				"maximizable": true,
				"visible": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
