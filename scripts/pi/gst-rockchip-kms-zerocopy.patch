diff --git a/gst/kmssrc/gstkmssrc.c b/gst/kmssrc/gstkmssrc.c
index 44b2157..e43765d 100644
--- a/gst/kmssrc/gstkmssrc.c
+++ b/gst/kmssrc/gstkmssrc.c
@@ -677,8 +677,20 @@ gst_kms_src_import_drm_fb (GstKmsSrc * self, guint fb_id)
       }
     }
 
-    mem = gst_fd_allocator_alloc (self->allocator, dmafd[i], st[i].st_size,
-              GST_FD_MEMORY_FLAG_NONE);
+    {
+      /* Some kernels report st_size == 0 for imported dmabufs; fall back to
+       * the FB geometry so the downstream size checks see the real size. */
+      gsize fdsize = st[i].st_size;
+
+      GST_DEBUG_OBJECT (self, "dmabuf fd %d st_size %" G_GSIZE_FORMAT,
+          dmafd[i], fdsize);
+
+      if (fdsize < fb.offsets[i] + (gsize) size[i])
+        fdsize = fb.offsets[i] + size[i];
+
+      mem = gst_fd_allocator_alloc (self->allocator, dmafd[i], fdsize,
+                GST_FD_MEMORY_FLAG_NONE);
+    }
     if (!mem) {
       close (dmafd[i]);
       goto err;
